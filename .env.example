# Copy to server/.env (never commit real secrets).

# --- Server (server/.env) ---
PORT=4000
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/ecommerce?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string-min-16
JWT_COOKIE_NAME=token
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=http://localhost:5173

# Google OAuth (redirect URI must match CLIENT_URL + /api/auth/google/callback when using Vite proxy)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails promoted to admin on first Google login
ADMIN_EMAILS=admin@example.com

# Razorpay — required for checkout (https://dashboard.razorpay.com → Account & Settings → API Keys)
# Use test keys (rzp_test_…) for development. In the dashboard, enable Card, UPI, netbanking, wallets, EMI, Pay Later as needed.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret — OPTIONAL. Only needed if you configure a Razorpay webhook URL to your server.
# Leave empty for test/local: checkout still works; the app verifies payments with KEY_SECRET on the client callback.
RAZORPAY_WEBHOOK_SECRET=

# Optional: Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed users (npm run seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_CUSTOMER_EMAIL=customer@example.com

# Sample catalog: 10 sarees + jewellery products (npm run seed, then npm run seed:products)
# Uses SEED_ADMIN_EMAIL (or admin@example.com) as createdBy.

# --- Client ---
# VITE_API_URL=http://localhost:4000
