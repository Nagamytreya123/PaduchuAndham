# Local dev: leave unset — Vite proxies /api to the server on :4000.
# Production on Vercel: leave unset if vercel.json proxies /api to Render (recommended).
# Only set when the API is on the same origin as the shop. Do not use *.onrender.com here
# or login cookies will not work.
# VITE_API_URL=https://your-api.example.com

# Optional: origin that serves /uploads (e.g. Render API). Use when local dev shares
# production MongoDB but uploads live on the deployed server — keeps VITE_API_URL local.
# VITE_MEDIA_ORIGIN=https://paduchuandham.onrender.com

# Google Analytics 4 (optional — omit to disable client analytics)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
